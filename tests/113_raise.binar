// exit: 0
// Test raise keyword for error propagation

fn div(a int, b int) (int, int) {
    if b == 0 {
        return 0, 1
    }
    return a / b, 0
}

fn inner() (int, int) {
    // raise: propagate error from div
    x := div(10, 2) raise
    return x + 100, 0
}

fn main() int {
    // Test raise with success
    r, err := inner()
    if err != 0 {
        return 1
    }
    if r != 105 {
        return 2
    }

    // Test that div with zero causes error
    _, err2 := div(1, 0)
    if err2 == 0 {
        return 3
    }

    return 0
}
